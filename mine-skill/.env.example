# Mine Agent Configuration

# Platform Service
PLATFORM_BASE_URL=https://api.minework.net

# Optional helper identifier.
# The lower-level platform identity is derived from the wallet signer address.
MINER_ID=mine-agent

# AWP Wallet
# Optional: leave this as awp-wallet unless you truly need a custom path.
AWP_WALLET_BIN=awp-wallet
# Get token from: awp-wallet unlock --duration 3600
AWP_WALLET_TOKEN=

# EIP-712 Signature Domain Parameters
# CRITICAL: These must match the platform's configuration
EIP712_DOMAIN_NAME=aDATA
EIP712_CHAIN_ID=8453
EIP712_VERIFYING_CONTRACT=0x0000000000000000000000000000000000000000

# Worker Configuration
# CRAWLER_ROOT=./crawlers
# OUTPUT_ROOT=./output
# STATE_ROOT=./state
# PYTHON_BIN=python
# MAX_PARALLEL=3
# DISCOVERY_MAX_PAGES=25
# DISCOVERY_MAX_DEPTH=1
