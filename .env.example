# AWP Miner Swarm - Environment Configuration Template
# Instructions: Copy this file to .env and fill in your details.

# 1. API Credentials (12 Dedicated Channels)
NVIDIA_API_KEY_1=
NVIDIA_API_KEY_2=
NVIDIA_API_KEY_3=
NVIDIA_API_KEY_4=
NVIDIA_API_KEY_5=
NVIDIA_API_KEY_6=
NVIDIA_API_KEY_7=
NVIDIA_API_KEY_8=
NVIDIA_API_KEY_9=
NVIDIA_API_KEY_10=
NVIDIA_API_KEY_11=
NVIDIA_API_KEY_12=
BASE_URL=https://integrate.api.nvidia.com/v1

# 2. Worker Settings
# MAX_PARALLEL: 15 is optimized for Ryzen 9700X (Ghost-Browser mode)
MAX_PARALLEL=15
DATASET_REFRESH_SECONDS=2
PYTHONIOENCODING=utf-8

# 3. Security (Wallets)
# These are used by the entrypoint to import your identities autonomously.
# Leave blank if you are managing wallets.json manually.
MINER_MNEMONIC_1=
MINER_MNEMONIC_2=
MINER_MNEMONIC_3=
MINER_MNEMONIC_4=
MINER_MNEMONIC_5=
MINER_MNEMONIC_6=
MINER_MNEMONIC_7=
MINER_MNEMONIC_8=
MINER_MNEMONIC_9=
MINER_MNEMONIC_10=
MINER_MNEMONIC_11=
MINER_MNEMONIC_12=
